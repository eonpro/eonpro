// ==========================================================================
// REPORTING ENGINE
// ==========================================================================
// Saved report templates and scheduled delivery for the enterprise
// reporting engine. Templates store the full report configuration
// (data source, columns, filters, groupBy, sortBy, chart type) as JSON.
// Schedules automate recurring report generation and email delivery.
// ==========================================================================

model ReportTemplate {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  clinicId         Int?
  clinic           Clinic?  @relation(fields: [clinicId], references: [id])
  createdById      Int
  createdBy        User     @relation("ReportTemplateCreator", fields: [createdById], references: [id])
  name             String
  description      String?
  dataSource       String   // "revenue", "commissions", "patients", "fulfillment", "provider", "affiliates", "subscriptions"
  config           Json     // { columns, filters, groupBy, sortBy, chartType, dateRange }
  isShared         Boolean  @default(false)
  isSystemTemplate Boolean  @default(false)
  accessRoles      String[] @default(["super_admin", "admin"])
  lastRunAt        DateTime?

  schedules ReportSchedule[]

  @@index([clinicId])
  @@index([createdById])
  @@index([dataSource])
  @@index([isSystemTemplate])
}

model ReportSchedule {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  templateId     Int
  template       ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdById    Int
  createdBy      User     @relation("ReportScheduleCreator", fields: [createdById], references: [id])
  clinicId       Int?
  clinic         Clinic?  @relation(fields: [clinicId], references: [id])
  frequency      String   // "daily", "weekly", "biweekly", "monthly"
  dayOfWeek      Int?     // 0=Sunday, 1=Monday, etc.
  dayOfMonth     Int?     // 1-28 for monthly
  timeUtc        String   @default("06:00") // HH:mm in UTC
  exportFormat   String   @default("csv")   // "csv", "pdf", "xlsx"
  recipients     String[]
  isActive       Boolean  @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  lastError      String?

  @@index([isActive, nextRunAt])
  @@index([templateId])
  @@index([clinicId])
}
