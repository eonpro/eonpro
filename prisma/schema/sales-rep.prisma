// ==========================================================================
// SALES REP DOMAIN
// ==========================================================================
// Bounded context: sales rep (intake URLs, touch tracking, attribution)
// Part of multi-file Prisma schema (prisma/schema/)
// ==========================================================================

// Shareable ref codes for sales rep intake URLs (like AffiliateRefCode)
model SalesRepRefCode {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  clinicId    Int
  clinic      Clinic   @relation(fields: [clinicId], references: [id])
  salesRepId  Int // User ID with SALES_REP role
  salesRep    User     @relation("SalesRepRefCodes", fields: [salesRepId], references: [id], onDelete: Cascade)
  refCode     String
  description String?
  isActive    Boolean  @default(true)

  @@unique([clinicId, refCode])
  @@index([clinicId])
  @@index([salesRepId])
  @@index([refCode])
}

// Multi-touch attribution for sales rep links (HIPAA-safe: no names/medical data)
model SalesRepTouch {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  clinicId  Int
  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  visitorFingerprint String
  cookieId           String?
  ipAddressHash      String?
  userAgent          String?

  salesRepId Int
  salesRep   User   @relation("SalesRepTouches", fields: [salesRepId], references: [id], onDelete: Cascade)
  refCode    String

  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  landingPage String?
  referrerUrl String?

  touchType TouchType @default(CLICK)

  convertedPatientId Int?
  convertedAt        DateTime?

  @@index([clinicId, visitorFingerprint])
  @@index([clinicId, cookieId])
  @@index([salesRepId])
  @@index([createdAt])
  @@index([refCode])
  @@index([salesRepId, convertedAt])
  @@index([refCode, createdAt])
  @@index([salesRepId, createdAt])
  @@index([salesRepId, touchType, createdAt])
}

// ==========================================================================
// SALES REP COMMISSION PLANS (dedicated area — separate from affiliates)
// ==========================================================================
// Commission plans for sales rep employees. Uses shared enums from affiliate domain.
// ==========================================================================

model SalesRepCommissionPlan {
  id              Int                 @id @default(autoincrement())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  clinicId        Int
  clinic          Clinic              @relation(fields: [clinicId], references: [id])
  name            String // e.g., "Standard 10%", "Tier 2 Rep"
  description     String?
  planType        CommissionPlanType   @default(PERCENT)
  flatAmountCents Int?
  percentBps      Int?
  appliesTo       CommissionAppliesTo  @default(FIRST_PAYMENT_ONLY)
  holdDays        Int                 @default(0)
  clawbackEnabled Boolean             @default(false)
  isActive        Boolean             @default(true)

  initialPercentBps      Int?
  initialFlatAmountCents Int?
  recurringPercentBps      Int?
  recurringFlatAmountCents Int?

  recurringEnabled Boolean @default(false)
  recurringMonths   Int?

  // Bonus when sale has multiple items (e.g. add extra % or $ per additional item)
  multiItemBonusEnabled   Boolean @default(false)
  multiItemBonusType      String?  // 'PERCENT' | 'FLAT'
  multiItemBonusPercentBps Int?
  multiItemBonusFlatCents  Int?
  multiItemMinQuantity     Int?    // apply when item count >= this (default 2)

  // Reactivation window: if a patient's last payment was more than this many days ago,
  // treat their next payment as a "new sale" for commission purposes (resets FIRST_PAYMENT_ONLY).
  // Null means no reactivation window (standard behavior: once a patient pays, all future payments are recurring).
  reactivationDays  Int?

  // Volume-based weekly tiers (e.g. 1-8 sales $5 each, 9-20 sales $10 each, 21+ sales $15 each)
  volumeTierEnabled    Boolean @default(false)
  volumeTierWindow     String? // 'CALENDAR_WEEK_MON_SUN' | 'REPORT_PERIOD'
  volumeTierRetroactive Boolean @default(true) // when true, highest reached tier applies to all sales in period

  assignments       SalesRepPlanAssignment[]
  productCommissions SalesRepProductCommission[]
  volumeTiers        SalesRepVolumeCommissionTier[]

  @@index([clinicId])
  @@index([isActive])
}

model SalesRepPlanAssignment {
  id               Int                       @id @default(autoincrement())
  createdAt        DateTime                  @default(now())
  clinicId         Int
  clinic           Clinic                    @relation(fields: [clinicId], references: [id])
  salesRepId       Int // User ID with sales_rep role
  salesRep         User                      @relation("SalesRepPlanAssignments", fields: [salesRepId], references: [id], onDelete: Cascade)
  commissionPlanId Int
  commissionPlan   SalesRepCommissionPlan   @relation(fields: [commissionPlanId], references: [id], onDelete: Restrict)
  effectiveFrom    DateTime                  @default(now())
  effectiveTo      DateTime?
  hourlyRateCents  Int?                     // Rep's hourly rate while on this plan (clinic-defined)

  @@index([clinicId])
  @@index([salesRepId])
  @@index([commissionPlanId])
  @@index([effectiveFrom, effectiveTo])
}

// Per-product or per-package commission override (clinic-customizable)
// When a rep sells this product or bundle, add this extra commission (% or $)
model SalesRepProductCommission {
  id               Int                     @id @default(autoincrement())
  createdAt        DateTime                @default(now())
  planId           Int
  plan             SalesRepCommissionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  productId        Int?                    // Specific product (optional)
  product          Product?                @relation(fields: [productId], references: [id], onDelete: Cascade)
  productBundleId  Int?                    // Specific package/bundle (optional)
  productBundle    ProductBundle?         @relation(fields: [productBundleId], references: [id], onDelete: Cascade)
  bonusType        String                  // 'PERCENT' | 'FLAT'
  percentBps       Int?                    // When bonusType = PERCENT
  flatAmountCents  Int?                    // When bonusType = FLAT

  @@index([planId])
  @@index([productId])
  @@index([productBundleId])
}

// Commission event ledger — records each commission earned by a sales rep.
// HIPAA-COMPLIANT: stores only financial data and IDs, never patient-identifiable information.
model SalesRepCommissionEvent {
  id                    Int      @id @default(autoincrement())
  createdAt             DateTime @default(now())
  clinicId              Int
  clinic                Clinic   @relation(fields: [clinicId], references: [id])
  salesRepId            Int
  salesRep              User     @relation("SalesRepCommissionEvents", fields: [salesRepId], references: [id])

  stripeEventId         String?
  stripeObjectId        String?
  stripeEventType       String?

  eventAmountCents      Int
  commissionAmountCents Int
  baseCommissionCents   Int      @default(0)
  volumeTierBonusCents  Int      @default(0)
  productBonusCents     Int      @default(0)
  multiItemBonusCents   Int      @default(0)

  commissionPlanId      Int?
  patientId             Int?

  isRecurring           Boolean  @default(false)
  recurringMonth        Int?

  status                CommissionEventStatus @default(PENDING)
  occurredAt            DateTime
  holdUntil             DateTime?
  approvedAt            DateTime?
  paidAt                DateTime?
  reversedAt            DateTime?
  reversalReason        String?

  isManual              Boolean  @default(false)
  notes                 String?
  metadata              Json?

  @@unique([clinicId, stripeEventId])
  @@index([salesRepId, status])
  @@index([clinicId, occurredAt])
  @@index([status, holdUntil])
  @@index([salesRepId, occurredAt])
}

// Per-plan, volume-based commission tiers for a weekly/reporting period.
// If retroactive is enabled on the plan, once a rep reaches a tier, that tier amount applies to all sales in that period.
model SalesRepVolumeCommissionTier {
  id               Int                    @id @default(autoincrement())
  createdAt        DateTime               @default(now())
  planId           Int
  plan             SalesRepCommissionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  minSales         Int
  maxSales         Int?                   // null means open-ended (e.g. 21+)
  amountCents      Int                    // flat dollar amount per sale in this tier
  sortOrder        Int                    @default(0)

  @@index([planId])
  @@index([planId, minSales])
}

// ==========================================================================
// SALES REP OVERRIDE COMMISSIONS (manager earns % of subordinate's revenue)
// ==========================================================================

// Links a senior/override rep to a subordinate rep.
// The override rep earns overridePercentBps of gross revenue from the subordinate's patients.
model SalesRepOverrideAssignment {
  id               Int      @id @default(autoincrement())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  clinicId         Int
  clinic           Clinic   @relation(fields: [clinicId], references: [id])

  overrideRepId    Int
  overrideRep      User     @relation("SalesRepOverrideManager", fields: [overrideRepId], references: [id])

  subordinateRepId Int
  subordinateRep   User     @relation("SalesRepOverrideSubordinate", fields: [subordinateRepId], references: [id])

  overridePercentBps Int // e.g. 50 = 0.5%, 100 = 1.0%, 150 = 1.5%

  effectiveFrom    DateTime  @default(now())
  effectiveTo      DateTime?
  isActive         Boolean   @default(true)

  assignedById     Int?
  notes            String?

  overrideEvents   SalesRepOverrideCommissionEvent[]

  @@unique([clinicId, overrideRepId, subordinateRepId])
  @@index([clinicId])
  @@index([overrideRepId])
  @@index([subordinateRepId])
  @@index([isActive])
}

// Ledger for override commissions earned by senior reps from subordinate rep revenue.
// HIPAA-COMPLIANT: stores only financial data and IDs, never patient-identifiable information.
model SalesRepOverrideCommissionEvent {
  id                      Int      @id @default(autoincrement())
  createdAt               DateTime @default(now())
  clinicId                Int
  clinic                  Clinic   @relation(fields: [clinicId], references: [id])

  overrideRepId           Int
  overrideRep             User     @relation("SalesRepOverrideCommEvents", fields: [overrideRepId], references: [id])

  subordinateRepId        Int

  sourceCommissionEventId Int?
  overrideAssignmentId    Int
  overrideAssignment      SalesRepOverrideAssignment @relation(fields: [overrideAssignmentId], references: [id])

  eventAmountCents        Int // Gross revenue (payment amount)
  overridePercentBps      Int // Rate snapshot at time of calculation
  commissionAmountCents   Int // Calculated override amount

  patientId               Int?
  stripeEventId           String?

  status                  CommissionEventStatus @default(PENDING)
  occurredAt              DateTime
  holdUntil               DateTime?
  approvedAt              DateTime?
  paidAt                  DateTime?
  reversedAt              DateTime?
  reversalReason          String?

  isManual                Boolean @default(false)
  notes                   String?
  metadata                Json?

  @@unique([clinicId, stripeEventId, overrideRepId])
  @@index([overrideRepId, status])
  @@index([clinicId, occurredAt])
  @@index([subordinateRepId, occurredAt])
  @@index([sourceCommissionEventId])
}
