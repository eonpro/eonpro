{
  "buildCommand": "npm run vercel-build",
  "functions": {
    "src/app/api/ai/chat/stream/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/patients/**/*.tsx": {
      "maxDuration": 30
    },
    "src/app/provider/**/*.tsx": {
      "maxDuration": 30
    }
  },
  "crons": [
    {"path": "/api/ping", "schedule": "*/5 * * * *"},
    {"path": "/api/cron/health-monitor", "schedule": "*/5 * * * *"},
    {"path": "/api/cron/portal-health", "schedule": "*/5 * * * *"},
    {"path": "/api/cron/process-message-queue", "schedule": "*/5 * * * *"},
    {"path": "/api/integrations/overtime/sync", "schedule": "*/15 * * * *"},
    {"path": "/api/cron/process-scheduled-emails", "schedule": "*/5 * * * *"},
    {"path": "/api/cron/email-digest", "schedule": "0 9 * * 1"},
    {"path": "/api/cron/platform-fees", "schedule": "0 0 * * 1"},
    {"path": "/api/cron/invoice-reminders", "schedule": "0 9 * * *"},
    {"path": "/api/cron/refill-scheduler", "schedule": "0 * * * *"},
    {"path": "/api/cron/refill-escalation", "schedule": "0 */4 * * *"},
    {"path": "/api/cron/shipment-reminders", "schedule": "0 10 * * *"},
    {"path": "/api/cron/daily-queue-summary", "schedule": "0 13 * * *"},
    {"path": "/api/cron/fedex-tracking", "schedule": "0 */3 * * *"},
    {"path": "/api/cron/comms-health", "schedule": "*/15 * * * *"},
    {"path": "/api/scheduling/reminders/process", "schedule": "*/10 * * * *"},
    {"path": "/api/cron/report-delivery", "schedule": "0 * * * *"},
    {"path": "/api/cron/affiliate-payouts", "schedule": "0 6 * * *"},
    {"path": "/api/cron/revenue-recognition", "schedule": "0 2 1 * *"}
  ]
}
